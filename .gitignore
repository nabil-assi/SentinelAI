cat <<EOF > .gitignore
# Dependency directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables (الحماية القصوى)
.env
backend/.env
frontend/.env.local

# Build outputs
dist/
.next/
out/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS metadata
.DS_Store
Thumbs.db
EOF